# ============================================================================
# Missed-Lead Recovery — Backend Environment Variables
# Copy this to .env.dev and .env.prod, then fill in real values.
# ============================================================================

# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_YOUR_SERVICE_KEY
SUPABASE_ANON_KEY=sb_publishable_YOUR_ANON_KEY

# Twilio
TWILIO_ACCOUNT_SID=YOUR_TWILIO_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_TOKEN
TWILIO_PHONE_NUMBER=+358000000000

# Calendly
CALENDLY_WEBHOOK_SECRET=YOUR_CALENDLY_SECRET

# Firebase (push notifications)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Google OAuth (for reference — actual config is in Supabase Dashboard)
GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET

# CORS (set for web dashboard, leave empty if mobile-only)
CORS_ORIGIN=

# Server
PORT=3000
